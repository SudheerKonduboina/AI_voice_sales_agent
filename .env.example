# Copy this file to .env and fill in real values. Never commit .env.
# Only needed once you move from simulate mode to live calling.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Only needed if you switch llm.provider to "openai" in config/config.yaml
OPENAI_API_KEY=

# Used by the optional "Notify Sales Team" node in the n8n workflow
SALES_TEAM_EMAIL=

# Docker and Local Service Configuration
OLLAMA_BASE_URL=http://localhost:11434
LOG_LEVEL=INFO
API_PORT=8000

